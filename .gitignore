.ropeproject

# Quarto build artifacts
/_site/
/_freeze/
/.quarto/

# quartodoc generated API reference (regenerated on build)
docs/reference/

# Ephemeral .ipynb for contract testing (convert → test → delete)
# Only .py percent-format is source of truth
notebooks/contracts/*.ipynb
notebooks/contracts/**/*.ipynb
# ALLOWED: slow-running contracts (pre-executed, committed with frozen outputs)
!notebooks/contracts/slow/**/*.ipynb
# ALLOWED: archived frozen notebooks (committed with outputs)
!notebooks/archive/**/*.ipynb

# Doc-rendering .ipynb (generated by `make notebooks`, cleaned by `make clean`)
# NOT gitignored — Quarto needs to discover them for rendering
# These are ephemeral: never commit, always regenerated from .py source

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

**/*.quarto_ipynb
