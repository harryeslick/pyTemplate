[project]
name = "{{ project_name }}"
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]
description = "{{ project_description }}"
readme = "README.md"
requires-python = ">=3.13"

dynamic = ["version"]
dependencies = [
    "pandas>=2.2.3",
    "numpy>=2.1.3",
    "matplotlib>=3.10.1",
]

[dependency-groups]
dev = [
    "quartodoc>=0.9.0",
    "griffe<2.0",
    "jupytext>=1.16.0",
    "nbformat>=5.10.0",
    "bandit[toml]==1.7.5",
    "pre-commit==3.3.1",
    "pytest-cov==4.0.0",
    "pytest==7.3.1",
    "pytest-github-actions-annotate-failures",
    "plotly>=5.24.1",
    "ipykernel>=6.29.5",
    "nbclient>=0.10.0",
    "rich",
]

# [project.urls]
# Documentation = "https://harryeslick.github.io/"
# Source = "https://github.com/harryeslick/"


[tool.ruff]
line-length = 100
indent-width = 4
extend-exclude = ["scratch.py"]

[tool.ruff.lint]
select = [
    "E",    # pycodestyle errors
    "F",    # pyflakes
    "I",    # isort
    "UP",   # pyupgrade (modern Python syntax)
    "SIM",  # flake8-simplify
]

[tool.ruff.lint.isort]
force-wrap-aliases = true
combine-as-imports = true

[tool.ruff.format]
quote-style = "double"
indent-style = "tab"
docstring-code-format = false

[tool.coverage.run]
branch = true


[tool.pytest.ini_options]
pythonpath = ["src"]
testpaths = "tests"

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.version]
path = "src/{{project_name}}/__init__.py"
